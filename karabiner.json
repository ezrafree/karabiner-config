{
    "global": { "ask_for_confirmation_before_quitting": false },
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Remap Caps Lock to Hyper (ctrl + alt + cmd) if used in combination with other keys, otherwise map it to F18",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "key_code": "left_command",
                                        "modifiers": ["left_control", "left_option"]
                                    }
                                ],
                                "to_if_alone": [
                                    {
                                        "key_code": "spacebar",
                                        "lazy": true,
                                        "modifiers": ["left_command"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Remap my 'Hey Siri' key to lock the screen",
                        "manipulators": [
                            {
                                "from": {
                                    "simultaneous": [
                                        { "key_code": "spacebar" },
                                        { "key_code": "fn" }
                                    ]
                                },
                                "to": [
                                    {
                                        "key_code": "q",
                                        "lazy": true,
                                        "modifiers": ["left_command", "left_control"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Map Command-Shift-Option-Control-Period to f19 (avoid System Diagnostics)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "period",
                                    "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
                                },
                                "to": { "key_code": "f19" },
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Map Command-Shift-Option-Control-Comma to f18 (avoid System Diagnostics)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "comma",
                                    "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
                                },
                                "to": { "key_code": "f18" },
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Map Command-Shift-Option-Control-w to f17 (avoid Wifi Diagnostics)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "w",
                                    "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
                                },
                                "to": { "key_code": "f17" },
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Map Command-Option-Control-c to Command-k (clear terminal)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "c",
                                    "modifiers": { "mandatory": ["left_command", "left_control", "left_option"] }
                                },
                                "to": {
                                    "key_code": "k",
                                    "modifiers": ["left_command"]
                                },
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Map Option-Shift-Left to Command-Control-Shift-Left (jump words in Chrome URL bar)",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.google\\.Chrome$"
                                        ],
                                        "description": "Google Chrome",
                                        "type": "frontmost_application_if"
                                    }
                                ],
                                "from": {
                                    "key_code": "left_arrow",
                                    "modifiers": { "mandatory": ["left_option", "left_shift"] }
                                },
                                "to": {
                                    "key_code": "left_arrow",
                                    "modifiers": ["left_command", "left_control", "left_shift"]
                                },
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Map Option-Shift-Right to Command-Control-Shift-Right (jump words in Chrome URL bar)",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.google\\.Chrome$"
                                        ],
                                        "description": "Google Chrome",
                                        "type": "frontmost_application_if"
                                    }
                                ],
                                "from": {
                                    "key_code": "right_arrow",
                                    "modifiers": { "mandatory": ["left_option", "left_shift"] }
                                },
                                "to": {
                                    "key_code": "right_arrow",
                                    "modifiers": ["left_command", "left_control", "left_shift"]
                                },
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
